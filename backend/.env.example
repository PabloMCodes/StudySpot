# Backend runtime configuration
# Copy to backend/.env and fill in real values.

DATABASE_URL=postgresql+psycopg://postgres:<SUPABASE_DB_PASSWORD>@<SUPABASE_HOST>:5432/postgres?sslmode=require

# Google Sign-In backend verification
GOOGLE_CLIENT_ID=

# Supabase auth token verification
SUPABASE_URL=
SUPABASE_ANON_KEY=
# Optional for server-side Storage uploads (recommended in production)
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=session-photos

# JWT for app auth
JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# Optional DB pool tuning (for non-serverless runtimes)
DB_POOL_SIZE=1
DB_MAX_OVERFLOW=0
DB_POOL_TIMEOUT=10

# Optional: only needed for scripts/fetch_orlando_locations.py
GOOGLE_PLACES_API_KEY=
