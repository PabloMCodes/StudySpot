# Frontend runtime configuration
# Copy to frontend/.env.local and fill in values.

# API base URL
EXPO_PUBLIC_API_URL=http://localhost:8000

# Privacy policy URL
EXPO_PUBLIC_PRIVACY_POLICY_URL=https://heliotrope-fedora-710.notion.site/StudySpot-Privacy-Policy-1ea4ab8980428357867d813699b9188b

# Support email address shown in app
EXPO_PUBLIC_SUPPORT_EMAIL=ehstudyspot@gmail.com

# Supabase auth (required for email/password login)
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Map provider toggle
# Use 'fallback' for Expo Go, 'mapbox' for dev-client/native builds
EXPO_PUBLIC_MAP_PROVIDER=fallback

# Mapbox public token
EXPO_PUBLIC_MAPBOX_ACCESS_TOKEN=

# Optional: custom Mapbox Studio style URL (example: mapbox://styles/<username>/<style_id>)
# Leave blank to use default Mapbox Street style
EXPO_PUBLIC_MAPBOX_STYLE_URL=

# Optional: expose Google Sign-In button in login screen
EXPO_PUBLIC_ENABLE_GOOGLE_LOGIN=false
